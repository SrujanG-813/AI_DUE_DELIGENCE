# AI Provider Configuration
# For Railway deployment, OpenAI API key is REQUIRED for embeddings

# OpenAI API Configuration (REQUIRED for Railway)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Mistral AI API Configuration (Optional - for LLM, will use OpenAI if not provided)
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Railway Deployment
# These will be set automatically by Railway
# PORT=8000
# RAILWAY_ENVIRONMENT=production
